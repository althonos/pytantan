# distutils: language = c++
# cython: language_level=3, linetrace=True, embedsignature=True, binding=True

from cpython.pycapsule cimport PyCapsule_New
from .. cimport tantan

cdef int maskSequences_impl(
    unsigned char* seqBeg,
    unsigned char* seqEnd,
    int maxRepeatOffset,
    const double** likelihoodRationMatrix,
    double repeatProb,
    double repeatEndProb,
    double repeatOffsetProbDecay,
    double firstGapProb,
    double otherGapProb,
    double minMaskProb,
    const unsigned char* maskTable
) except 1 nogil:
    tantan.maskSequences(
        seqBeg,
        seqEnd,
        maxRepeatOffset,
        likelihoodRationMatrix,
        repeatProb,
        repeatEndProb,
        repeatOffsetProbDecay,
        firstGapProb,
        otherGapProb,
        minMaskProb,
        maskTable,
    )
    return 0


cdef int getProbabilities_impl(
    const unsigned char* seqBeg,
    const unsigned char* seqEnd,
    int maxRepeatOffset,
    const double** likelihoodRationMatrix,
    double repeatProb,
    double repeatEndProb,
    double repeatOffsetProbDecay,
    double firstGapProb,
    double otherGapProb,
    float* probabilities
) except 1 nogil:
    tantan.getProbabilities(
        seqBeg,
        seqEnd,
        maxRepeatOffset,
        likelihoodRationMatrix,
        repeatProb,
        repeatEndProb,
        repeatOffsetProbDecay,
        firstGapProb,
        otherGapProb,
        probabilities,
    )
    return 0


maskSequences    = PyCapsule_New(<void*> maskSequences_impl,    NULL,    NULL)
getProbabilities = PyCapsule_New(<void*> getProbabilities_impl, NULL, NULL)
